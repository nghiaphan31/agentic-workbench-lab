#!/bin/sh
# pre-push hook — The Arbiter's Physical Barrier
#
# Owner: The Arbiter (Layer 2b)
# Version: 2.1
# Location: .workbench/hooks/pre-push
#
# This hook runs BEFORE any push is executed.
# It enforces:
#   1. Blocking push if state is RED, REGRESSION_RED, INTEGRATION_RED, or PIVOT_IN_PROGRESS
#   2. Blocking direct push to main (PR-only merges)
#   3. CONFLICT_DETECTED warning if modified file is owned by another in-flight feature
#
# Exit codes:
#   0 = push allowed
#   1 = push blocked

set -e

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "[PRE-PUSH] Running Arbiter pre-push checks..."

# =============================================================================
# 1. BLOCKING STATES CHECK
# =============================================================================
BLOCKING_STATES="RED REGRESSION_RED INTEGRATION_RED PIVOT_IN_PROGRESS"

# Read current state from state.json
if [ -f "state.json" ]; then
    CURRENT_STATE=$(python -c "import json; s=json.load(open('state.json')); print(s.get('state',''))" 2>/dev/null || echo "UNKNOWN")

    for blocking in $BLOCKING_STATES; do
        if [ "$CURRENT_STATE" = "$blocking" ]; then
            echo "[PRE-PUSH] ${RED}BLOCKED: Cannot push while state=$CURRENT_STATE${NC}"
            echo "  Pipeline must reach GREEN before pushing."
            echo "  Run: python .workbench/scripts/test_orchestrator.py run --scope full --set-state"
            exit 1
        fi
    done
fi

# =============================================================================
# 2. DIRECT PUSH TO MAIN BLOCKED
# =============================================================================
TARGET_BRANCH=$(git rev-parse --abbrev-ref HEAD)
# Get the remote being pushed to
REMOTE_NAME="$1"
REMOTE_URL="$2"

# If pushing to main, block unless it's a merge commit
if [ "$TARGET_BRANCH" = "main" ]; then
    # Check if this is a merge commit
    PARENT_COUNT=$(git rev-list --parents -n 1 HEAD | awk '{print NF-1}')
    if [ "$PARENT_COUNT" -lt 2 ]; then
        echo "[PRE-PUSH] ${RED}BLOCKED: Direct commit to main is forbidden${NC}"
        echo "  All changes to main must arrive via PR merge."
        echo "  Create a feature branch: git checkout -b feature/..."
        exit 1
    fi
fi

# =============================================================================
# 3. FILE OWNERSHIP CONFLICT DETECTION
# =============================================================================
if [ -f "state.json" ]; then
    MODIFIED_FILES=$(git diff --name-only HEAD 2>/dev/null || true)

    if [ -n "$MODIFIED_FILES" ]; then
        FILE_OWNERSHIP=$(python -c "
import json
with open('state.json') as f:
    s = json.load(f)
ownership = s.get('file_ownership', {})
for file, req_id in ownership.items():
    print(f'{file}:{req_id}')
" 2>/dev/null || true)

        if [ -n "$FILE_OWNERSHIP" ]; then
            CONFLICTS=""
            for modified in $MODIFIED_FILES; do
                for entry in $FILE_OWNERSHIP; do
                    owned_file=$(echo "$entry" | cut -d: -f1)
                    owner_req=$(echo "$entry" | cut -d: -f2)
                    if [ "$modified" = "$owned_file" ]; then
                        # Check if owner is MERGED
                        OWNER_STATE=$(python -c "
import json
with open('state.json') as f:
    s = json.load(f)
registry = s.get('feature_registry', {})
req = registry.get('$owner_req', {})
print(req.get('state', 'UNKNOWN'))
" 2>/dev/null || echo "UNKNOWN")

                        if [ "$OWNER_STATE" != "MERGED" ]; then
                            CONFLICTS="$CONFLICTS\n  - $modified owned by $owner_req (state=$OWNER_STATE)"
                        fi
                    fi
                done
            done

            if [ -n "$CONFLICTS" ]; then
                echo "[PRE-PUSH] ${YELLOW}WARNING: File ownership conflicts detected${NC}"
                echo "  The following files are modified but owned by in-flight features:"
                echo "$CONFLICTS"
                echo "  These conflicts will be flagged at HITL 2 review."
                echo "  Push continues but conflicts are noted."
                # Don't hard-block — conflicts are flagged for HITL 2 review
            fi
        fi
    fi
fi

# =============================================================================
# ALL CHECKS PASSED
# =============================================================================
echo "[PRE-PUSH] ${GREEN}All checks passed — push allowed${NC}"
exit 0