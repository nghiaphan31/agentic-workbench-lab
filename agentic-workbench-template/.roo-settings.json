{
  "$schema": "https://agentic-workbench.io/roo-settings.schema.json",
  "version": "2.1",
  "settings": {
    "roo-cline.allowedCommands": [
      "git log",
      "git diff",
      "git show",
      "git status",
      "git branch -a",
      "git log --oneline -n 20",
      "git diff --stat",
      "node --version",
      "mkdir",
      "type nul",
      "cat",
      "grep",
      "find",
      "ls -la",
      "ls",
      "pwd",
      "echo",
      "head -n 100",
      "tail -n 100",
      "wc -l"
    ],
    "roo-cline.deniedCommands": [
      "git push",
      "git commit",
      "git merge",
      "git rebase",
      "rm -rf",
      "docker",
      "kubectl",
      "terraform",
      "sudo",
      "chmod",
      "chown",
      "kill",
      "killall",
      "pkill",
      "npm test",
      "npx vitest",
      "pnpm test",
      "pytest",
      "make test",
      "npx gherkin-lint",
      "cucumber",
      "npm run test:integration",
      "npx vitest --integration"
    ]
  },
  "arbiter_owned": {
    "test_orchestrator": "python .workbench/scripts/test_orchestrator.py",
    "integration_test_runner": "python .workbench/scripts/integration_test_runner.py",
    "dependency_monitor": "python .workbench/scripts/dependency_monitor.py",
    "gherkin_validator": "python .workbench/scripts/gherkin_validator.py",
    "memory_rotator": "python .workbench/scripts/memory_rotator.py",
    "audit_logger": "python .workbench/scripts/audit_logger.py",
    "crash_recovery": "python .workbench/scripts/crash_recovery.py",
    "git_hooks": "pre-commit, pre-push, post-merge, post-tag"
  }
}